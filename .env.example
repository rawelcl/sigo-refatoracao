# SIGO Portal - variaveis de ambiente para docker-compose
# Copie para .env e ajuste. NAO commitar .env (esta no .gitignore).

# ============================================================
# Credenciais Copilot
# ============================================================
# Opcao A: token GitHub (sera trocado por token Copilot internamente).
GITHUB_TOKEN=

# Opcao B: token Copilot direto (1h de validade, sem refresh).
# COPILOT_TOKEN=

# Opcao C: deixar ambos vazios e logar via /auth (Device Flow).
# O token fica em output/.auth/github.json (persistido pelo volume).

# ============================================================
# Caminhos das fontes externas no HOST
# ============================================================
# CVS legado SIGO (procedure/, function/, package/).
CVS_HOST_PATH=C:/CVS/health_install

# Repositorio de ADRs de arquitetura Hapvida.
ADRS_HOST_PATH=C:/Users/thiagorc/Documents/Repos/Refatoracao/adrs arquitetura hapvida

# ============================================================
# Proxy corporativo (opcional)
# ============================================================
# HTTPS_PROXY=http://proxy.empresa:8080
# HTTP_PROXY=http://proxy.empresa:8080
# NO_PROXY=localhost,127.0.0.1

# ============================================================
# Limites do orquestrador (opcionais)
# ============================================================
# EXEC_MAX_ITER=50
# EXEC_MAX_CONCURRENT=1
# TOOL_RESULT_MAX_CHARS=24000
# RUN_COMMAND_TIMEOUT_MS=60000
