BoundedContext Reembolso {
    type = SUPPORTING_DOMAIN
    domainVisionStatement = "Gerencia configuraçăo de reembolso por plano, incluindo prazos, tipos e composiçőes."
    
    responsibilities = "Recuperar prazos de reembolso",
                       "Recuperar tipos de prazo",
                       "Recuperar tabelas de reembolso",
