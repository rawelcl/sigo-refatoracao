                       "Inserir mínimo contratual da empresa (sq_empresa_minimo_contratual)"
}

/* ???????????????????????????????????????????????????????????????????????????
   CONTEXT MAP - Relacionamentos entre Bounded Contexts
   ??????????????????????????????????????????????????????????????????????????? */

ContextMap CadastarEmpresaConveniada {
    type = SYSTEM_LANDSCAPE
    state = AS_IS

    contains OrquestracaoCadastramento
    contains ValidacaoProposta
    contains GestaoPessoaJuridica
    contains GestaoEnderecoComunicacao
    contains FilialAreaVenda
    contains ParametrizacaoNegocio
    contains Precificacao
    contains EmpresaConveniada
    contains Coparticipacao
    contains Carencia
    contains Fidelizacao
    contains AcessoInternet
    contains IntegracaoOdonto
    contains LogAuditoria
    contains Reembolso
    contains MinimoContratual

    /* Orquestraçăo coordena todos os contextos (Downstream) */
    OrquestracaoCadastramento [SK] <-> [SK] ValidacaoProposta
    OrquestracaoCadastramento [SK] <-> [SK] GestaoPessoaJuridica
    OrquestracaoCadastramento [SK] <-> [SK] GestaoEnderecoComunicacao
    OrquestracaoCadastramento [SK] <-> [SK] FilialAreaVenda
    OrquestracaoCadastramento [SK] <-> [SK] ParametrizacaoNegocio
    OrquestracaoCadastramento [SK] <-> [SK] Precificacao
    OrquestracaoCadastramento [SK] <-> [SK] EmpresaConveniada
    OrquestracaoCadastramento [SK] <-> [SK] Coparticipacao
    OrquestracaoCadastramento [SK] <-> [SK] Carencia
    OrquestracaoCadastramento [SK] <-> [SK] Fidelizacao
    OrquestracaoCadastramento [SK] <-> [SK] AcessoInternet
    OrquestracaoCadastramento [SK] <-> [SK] IntegracaoOdonto
    OrquestracaoCadastramento [SK] <-> [SK] LogAuditoria
    OrquestracaoCadastramento [SK] <-> [SK] Reembolso
    OrquestracaoCadastramento [SK] <-> [SK] MinimoContratual

    /* Dependęncias entre contextos */
    FilialAreaVenda [U] -> [D] ParametrizacaoNegocio
    ParametrizacaoNegocio [U] -> [D] Precificacao
    Precificacao [U] -> [D] EmpresaConveniada
    EmpresaConveniada [U] -> [D] Coparticipacao
    EmpresaConveniada [U] -> [D] Carencia
    EmpresaConveniada [U] -> [D] Fidelizacao
    EmpresaConveniada [U] -> [D] AcessoInternet
    EmpresaConveniada [U] -> [D] IntegracaoOdonto
    EmpresaConveniada [U] -> [D] MinimoContratual
    Coparticipacao [U] -> [D] Reembolso

    /* Log é consumido por todos */
    ValidacaoProposta [U] -> [D] LogAuditoria
    GestaoPessoaJuridica [U] -> [D] LogAuditoria
}
