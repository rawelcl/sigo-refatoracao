/**
 * ============================================================================
 * CONTEXT MAP - Refatoraçăo DDD: pr_cadastramento_empresa_prov
 * ============================================================================
 * 
 * Procedure Original: humaster.pr_cadastramento_empresa_prov
 * Linhas: ~5.000 (monólito procedural)
 * Responsabilidades identificadas: 14 domínios distintos
 * 
 * Estratégia: Strangler Fig Pattern
 *   Fase 1 - Separar em packages PL/SQL por Bounded Context
 *   Fase 2 - Expor via APIs REST (ASP.NET Core 8 Minimal APIs)
 *   Fase 3 - Migrar para serviços independentes (Azure Container Apps)
 * 
 * Stack de Modernizaçăo (Fase 3):
 *   Runtime:        .NET 8+ / ASP.NET Core 8 Minimal APIs
 *   Gateway:        Azure API Management
 *   Orquestraçăo:   Azure Durable Functions (Saga Pattern)
 *   Mensageria:     Azure Service Bus (Topics + Subscriptions)
 *   Autenticaçăo:   Microsoft Entra ID
 *   Banco de Dados: Azure SQL Database (Database per Service)
 *   Hosting:        Azure Container Apps
 *   Frontend:       Blazor WebAssembly ou React + TypeScript
 *   ORM:            Entity Framework Core
 *   Validaçăo:      FluentValidation
 *   Mediator/CQRS:  MediatR
 *   Observability:  Azure Application Insights + Azure Monitor
 *   CI/CD:          Azure DevOps Pipelines
 * 
 * Data: 2026-02-18
 * ============================================================================
 */

/* ???????????????????????????????????????????????????????????????????????????
   BOUNDED CONTEXTS (Domínios Identificados na Procedure)
   ??????????????????????????????????????????????????????????????????????????? */

/**
 * BC-01: Orquestraçăo do Cadastramento
 * -------------------------------------
 * Responsabilidade: Coordenar todo o fluxo de criaçăo de empresa conveniada.
 * É o "Application Service" que orquestra os demais contextos.
 * 
 * Canais de Entrada:
 *   - TAFFIX (Oracle Forms): Tela interna de cadastro
 *   - BITIX (Ferramenta de Vendas): Plataforma usada pelo vendedor/corretor
 *   Ambos gravam propostas em tb_empresa_internet
 * 
 * Procedure atual: pr_cadastramento_empresa_prov (corpo principal)
 * Package alvo:    pk_cadastramento_empresa
 * 
 * Tabelas: tb_empresa_internet (leitura)
 * Operaçăo: tp_operacao = '1' (inclusăo)
 */
BoundedContext OrquestracaoCadastramento {
    type = APPLICATION
    domainVisionStatement = "Orquestra o fluxo completo de cadastramento de empresa conveniada, coordenando validaçőes, persistęncia e integraçőes entre contextos."
    
    responsibilities = "Orquestrar fluxo de inclusăo", 
                       "Gerenciar transaçăo (commit/rollback)", 
                       "Tratar erros globais e pendęncias",
                       "Registrar resultado do processamento"
    
    /* Aggregate Root */
    Aggregate ProcessoCadastramento {
        Entity ProcessoCadastramento {
            aggregateRoot
            - ControleInternet nu_controle
            - EmpresaConveniada cd_empresa
            String tp_operacao
            String fl_status_processamento
            String p_erro_controle
        }
    }
}

/**
 * BC-02: Validaçăo de Dados da Proposta
 * ----------------------------------------
 * Responsabilidade: Validar todos os campos de entrada da proposta.
 * Linhas originais: ~600 linhas (críticas de CNPJ, razăo social, fantasia,
 *                   endereço, email, data pagamento, validade contrato, etc.)
 * 
 * Package alvo: pk_validacao_proposta
 * 
 * PROBLEMA ATUAL: Cada validaçăo tem ~15 linhas de código boilerplate 
 *                 (log odonto + raise_application_error), repetido 25+ vezes.
 * SOLUÇĂO: Extrair para procedure genérica de log+erro.
 */
BoundedContext ValidacaoProposta {
    type = CORE_DOMAIN
    domainVisionStatement = "Centraliza todas as regras de validaçăo de dados de entrada para cadastramento de empresa conveniada."
    
    responsibilities = "Validar CNPJ/CPF (pk_administracao.fn_check_cic)",
                       "Validar CAEPF (fn_check_caepf)",
                       "Validar dados cadastrais (razăo social, fantasia, contato, cargo)",
                       "Validar endereço (CEP, UF, cidade, bairro, logradouro, complemento)",
                       "Validar e-mail",
                       "Validar inscriçăo estadual",
                       "Validar data pagamento (1-30)",
                       "Validar validade do contrato (mínimo 6 meses para năo-padrăo)",
                       "Validar vendedor do plano",
                       "Validar lista negra de CNPJ",
                       "Validar natureza da empresa (0-9)",
                       "Validar quantidade de beneficiários"
}

/**
 * BC-03: Gestăo de Pessoa Jurídica
 * ----------------------------------
 * Responsabilidade: CRUD de pessoa (tb_pessoa) vinculada ŕ empresa.
 * 
 * Package alvo: pk_pessoa_juridica
 * 
 * Tabelas: tb_pessoa
 * Operaçőes: INSERT ou UPDATE baseado na existęncia do CNPJ
 */
BoundedContext GestaoPessoaJuridica {
    type = CORE_DOMAIN
    domainVisionStatement = "Gerencia o ciclo de vida da entidade Pessoa Jurídica no sistema, incluindo criaçăo e atualizaçăo de dados cadastrais."
    
    responsibilities = "Verificar existęncia de pessoa por CNPJ",
                       "Criar nova pessoa (sq_pessoa.nextval + fn_digito_out)",
                       "Atualizar pessoa existente",
                       "Determinar tipo pessoa (CPF=1, CNPJ=2) via fn_check_cic"

    Aggregate PessoaJuridica {
        Entity Pessoa {
            aggregateRoot
            - CdPessoa cd_pessoa
            String nu_cgc_cpf
            String nm_pessoa_razao_social
            String nm_fantasia
            int fl_tipo_pessoa
            String nu_ident_insc_est
            int cd_empresa_plano
        }
    }
}

/**
 * BC-04: Gestăo de Endereço e Comunicaçăo
 * ------------------------------------------
 * Responsabilidade: Gerenciar endereços, contatos e meios de comunicaçăo.
 * 
 * Package alvo: pk_endereco_comunicacao
 * 
 * Tabelas: tb_endereco_pessoa, tb_empresa_endereco, 
 *          tb_contato_pessoa, tb_meio_comunicacao_pessoa
 * 
 * Meios: telefone, fax, telex, celular, bip, cx postal, email
 */
BoundedContext GestaoEnderecoComunicacao {
    type = SUPPORTING_DOMAIN
    domainVisionStatement = "Gerencia endereços de correspondęncia, contatos empresariais e meios de comunicaçăo (telefone, fax, celular, email, etc.)."
    
    responsibilities = "Cadastrar endereço de correspondęncia (Affix reusa, demais cria novo)",
                       "Vincular endereço ŕ empresa (tb_empresa_endereco)",
                       "Cadastrar contato da empresa",
                       "Cadastrar meios de comunicaçăo (telefone, fax, telex, celular, bip, cx postal, email)",
                       "Validar CEP via tb_cep_logradouro e tb_cep_localidade"
}

/**
 * BC-05: Determinaçăo de Filial e Área de Venda
 * ------------------------------------------------
 * Responsabilidade: Resolver a filial correta para o contrato.
 * 
 * Package alvo: pk_filial_area_venda
 * 
 * Regras: vendedor ? área de venda ? filial
 *         Sobrescrito por: cd_filial_contrato, tb_emp_internet_filial (TAFFIX)
 */
BoundedContext FilialAreaVenda {
    type = SUPPORTING_DOMAIN
    domainVisionStatement = "Determina a filial e área de venda correta para o contrato, considerando vendedor, filial do contrato e parametrizaçăo TAFFIX."
    
    responsibilities = "Recuperar filial via vendedor/área de venda",
                       "Aplicar override filial_contrato (Sacti 1026849)",
                       "Aplicar override filial_modelo (tela TAFFIX)",
                       "Recuperar empresa_plano da filial"
}

/**
 * BC-06: Parametrizaçăo de Negócio (Modelo de Negócio)
 * -------------------------------------------------------
 * Responsabilidade: Buscar parâmetros do modelo de negócio
 *                   (tb_empresa_neg) com base em filial, natureza, 
 *                   qtd beneficiários.
 * 
 * Package alvo: pk_modelo_negocio
 * 
 * Tabelas: tb_empresa_neg, tb_empresa_neg_tabela, tb_empresa_neg_desconto,
 *          tb_empresa_neg_franquia, tb_empresa_neg_carencia, 
 *          tb_empresa_neg_grupo, tb_empresa_neg_modulo
 * 
 * ATENÇĂO: Lógica SIGO vs BITIX (dois caminhos paralelos)
 */
BoundedContext ParametrizacaoNegocio {
    type = CORE_DOMAIN
    domainVisionStatement = "Resolve os parâmetros do modelo de negócio aplicável ao contrato, incluindo tabelas de preço, descontos, caręncias e franquias."
    
    responsibilities = "Buscar parâmetros SIGO (cr_empresa_neg)",
                       "Buscar parâmetros BITIX (cr_empresa_neg_bitix)",
                       "Resolver total de empregados (coligadas SIGO e BITIX)",
                       "Determinar modelo de negócio e tabela de saúde",
                       "Determinar canal de venda (1=até 29, 2=30-99)",
                       "Determinar flag tabela geral (modelo != 1 com tabela)"
}

/**
 * BC-07: Precificaçăo e Tabela de Preços
 * ------------------------------------------
 * Responsabilidade: Criar tabelas de preço (titulares e agregados),
 *                   valores de plano e descontos.
 * 
 * Package alvo: pk_precificacao
 * 
 * Tabelas: tb_preco_plano, tb_valor_plano, tb_desconto_preco_plano
 */
BoundedContext Precificacao {
    type = CORE_DOMAIN
    domainVisionStatement = "Gerencia a criaçăo de tabelas de preço, valores de planos (titulares e agregados), e descontos aplicáveis ao contrato."
    
    responsibilities = "Criar tabela de preço principal (fn_cd_tb_preco_plano)",
                       "Criar tabela de preço agregados",
                       "Inserir valores de plano com fator de desconto (constante_vl)",
                       "Inserir descontos por faixa de usuários",
                       "Reusar tabela geral quando modelo != 1 (Affix)"
}

