                       "Verificar operadora automática"
}

/**
 * BC-14: Log e Auditoria
 * -------------------------
 * Responsabilidade: Registrar logs de processamento e erros.
 * 
 * Package alvo: pk_log_auditoria
 * 
 * Tabelas: tb_log_baixa_controle, tb_pendencia_empresa_internet
 * 
 * PROBLEMA ATUAL: Código de log repetido 30+ vezes na procedure
 *                 (boilerplate de ~12 linhas cada)
 * SOLUÇĂO: Procedure única pr_registra_log(nu_controle, mensagem, status)
 */
BoundedContext LogAuditoria {
    type = GENERIC_SUBDOMAIN
    domainVisionStatement = "Centraliza o registro de logs de processamento, auditoria e pendęncias, eliminando duplicaçăo de código de logging."
    
    responsibilities = "Registrar log de baixa controle (tb_log_baixa_controle)",
                       "Registrar pendęncias (tb_pendencia_empresa_internet)",
                       "Registrar erros de processamento"
}

