 * Sacti: 1684652
 */
BoundedContext MinimoContratual {
    type = SUPPORTING_DOMAIN
    domainVisionStatement = "Gerencia regras de mínimo contratual, incluindo vigęncia, multas, faturamento mínimo e quantidade de vidas."
    
