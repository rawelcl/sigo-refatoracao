 */
BoundedContext EmpresaConveniada {
    type = CORE_DOMAIN
    domainVisionStatement = "Gerencia o ciclo de vida do contrato da empresa conveniada, incluindo unidades, parâmetros, histórico e configuraçőes regulatórias."
    
    responsibilities = "Gerar código empresa (fn_empresa_conveniada)",
                       "Inserir empresa conveniada com todas as parametrizaçőes",
                       "Criar unidade da empresa",
                       "Configurar parâmetros de unidade (titulares + agregados)",
                       "Configurar parâmetros de plano especial (tb_parametros_unidade_pln_esp)",
                       "Registrar histórico (empresas simples/PME)",
                       "Configurar flags de saúde",
                       "Atualizar natureza jurídica",
                       "Inserir breakeven (valor padrăo 70)",
                       "Configurar RN 279/309 (tabela inativos)"
}

